<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>
</head>
<body>
    
    <h1><%= titulo %></h1>

    <form action="/cadastro" method="post">
        <input type="hidden" name="id_tarefa" id="id_tarefa" value="<%= id_tarefa %>">
        <label for="tarefa">Tarefa:</label> <br>
        <textarea name="tarefa" id="tarefa"><%= tarefa.nome_tarefa %></textarea> <br>
        <label for="prazo">Prazo:</label> <br>
        <input type="date" name="prazo" id="prazo" value="<%= moment(tarefa.prazo_tarefa).format("YYYY-MM-DD") %>"> <br>
        <label for="situacao">Situaçâo:</label> <br>
        <% 
            let situacao = ["","","","",""];
            situacao[tarefa.situacao_tarefa] = "selected";
        
        %>
        <select name="situacao" id="situacao">
            <option <%= situacao[0] %> value="0">Cancelada</option>
            <option <%= situacao[1] %> value="1">Pendente</option>
            <option <%= situacao[2] %> value="2">Iniciada</option>
            <option <%= situacao[3] %> value="3">Finalizada</option>
            <option <%= situacao[4] %> value="4">Em atraso</option>
        </select> <br>
        <button type="submit">Salvar</button>
    </form>

</body>
</html>